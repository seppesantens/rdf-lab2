@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix lab: <https://seppesantens.github.io/rdf-lab2/vocab.ttl#> .

lab:Person a rdfs:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A Person, dead or alive, fictional or real." .