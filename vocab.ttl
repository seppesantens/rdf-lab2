@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix lab: <https://seppesantens.github.io/rdf-lab2/vocab.ttl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

lab:Person a rdfs:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A person, dead or alive." ;
    rdfs:subClassOf foaf:Person .

lab:Organization a rdfs:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "An organization, profit or non-profit." ;
    rdfs:subClassOf foaf:Organization .

lab:Course a rdfs:Class ;
    rdfs:label "Course" ;
    rdfs:comment "A course offered at an educational institution." .

lab:Photograph a rdfs:Class ;
    rdfs:label "Photograph" ;
    rdfs:comment "A photograph, typically published on the web." ;
    rdfs:subClassOf foaf:Image .

lab:Place a rdfs:Class ;
    rdfs:label "Place" ;
    rdfs:comment "A physical location where an event or activity took place." .

lab:name a rdf:Property ;
    rdfs:label "name" ;
    rdfs:comment "The name of a resource" ;
    rdfs:domain rdfs:Resource ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf foaf:name .

lab:birthDate a rdf:Property ;
    rdfs:label "birth date" ;
    rdfs:comment "Date of birth." ;
    rdfs:domain lab:Person ;
    rdfs:range rdfs:Literal .

lab:worksFor a rdf:Property ;
    rdfs:label "works for" ;
    rdfs:comment "Relates a person to the organization they work for." ;
    rdfs:domain lab:Person ;
    rdfs:range lab:Organization .

lab:hasInterest a rdf:Property ;
    rdfs:label "has interest" ;
    rdfs:comment "Indicates a topic or activity that this person is interested in." ;
    rdfs:domain lab:Person ;
    rdfs:range rdfs:Resource .

lab:enrolledIn a rdf:Property ;
    rdfs:label "enrolled in" ;
    rdfs:comment "Relates a person to a course they are enrolled in." ;
    rdfs:domain lab:Person ;
    rdfs:range lab:Course .

lab:sameAs a rdf:Property ;
    rdfs:label "same as" ;
    rdfs:comment "Links a resource to an equivalent resource." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range rdfs:Resource .

lab:knows a rdf:Property ;
    rdfs:label "knows" ;
    rdfs:comment "Indicates that this person knows another person." ;
    rdfs:domain lab:Person ;
    rdfs:range lab:Person ;
    rdfs:subPropertyOf foaf:knows .

lab:title a rdf:Property ;
    rdfs:label "title" ;
    rdfs:comment "The title of a photograph." ;
    rdfs:domain lab:Photograph ;
    rdfs:range rdfs:Literal;
    rdfs:subPropertyOf foaf:name .

lab:creator a rdf:Property ;
    rdfs:label "creator" ;
    rdfs:comment "The person who took the photograph." ;
    rdfs:domain lab:Photograph ;
    rdfs:range lab:Person;
    rdfs:subPropertyOf foaf:maker .

lab:depicts a rdf:Property ;
    rdfs:label "depicts" ;
    rdfs:comment "A person or thing shown in the photograph." ;
    rdfs:domain lab:Photograph ;
    rdfs:range rdfs:Resource ;
    rdfs:subPropertyOf foaf:depicts .

lab:placeTaken a rdf:Property ;
    rdfs:label "place taken" ;
    rdfs:comment "The place where the photograph was taken." ;
    rdfs:domain lab:Photograph ;
    rdfs:range lab:Place .

lab:description a rdf:Property ;
    rdfs:label "description" ;
    rdfs:comment "A textual summary or description of the photograph." ;
    rdfs:domain lab:Photograph ;
    rdfs:range rdfs:Literal .

lab:imageUrl a rdf:Property ;
    rdfs:label "image URL" ;
    rdfs:comment "A URL pointing directly to the image file of a photograph." ;
    rdfs:domain lab:Photograph ;
    rdfs:range rdfs:Resource .